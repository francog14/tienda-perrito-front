{
  "containerDefinitions": [
    {
      "name": "frontend-container",
      "image": "193419803239.dkr.ecr.us-east-1.amazonaws.com/tienda-perrito-frontend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "name": "frontend-container-80-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tarea-frontend",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "tarea-frontend",
  "taskRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "executionRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
